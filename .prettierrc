{
  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 200,
  "tabWidth": 4,
  "endOfLine": "auto",
  "plugins": [
    "prettier-plugin-glsl"
  ],
  "overrides": [
    {
      "files": ["*.glsl", "*.vert", "*.frag"],
      "options": {
        "parser": "glsl-parser"
      }
    }
  ]
}